# RIFT Environment Configuration
# Copy this file to ~/.rift/.env and fill in your values:
#   cp .env.example ~/.rift/.env
#
# AWS credentials are required for data (rift sync).
# Wallet credentials are required for live trading (rift auth setup).

# ─── AWS (Historical Data from S3) ─────────────────────────
# Required for rift sync. Create free account at aws.amazon.com
# IAM → Create User → Attach AmazonS3ReadOnlyAccess → Create Access Key
# Cost: ~$2 for full data download, ~$0.30/month ongoing
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1

# ─── HYPERLIQUID TRADING ────────────────────────────────────
# Set automatically by rift auth setup (QR scan with wallet).
# Only needed for live trading — research works without these.
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_ACCOUNT_ADDRESS=
